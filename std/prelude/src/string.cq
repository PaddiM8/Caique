use object;

class String
{
    Bytes: i8*;
    Length: isize;

    init(Bytes, Length) {}

    fn concat(str: String): String {
        Length = Length + str.Length;
        let newStr = malloc(Length);
        strcat(newStr, Bytes);
        strcat(newStr, str.Bytes);

        new String(newStr, Length)
    }
}

fn free(a: i8*);
fn strcat(a: i8*, b: i8*);
fn malloc(size: isize): i8*;