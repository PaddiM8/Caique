fn printf(x: i8*, y: i8*): i32;
fn gets(out: i8*);
fn malloc(size: i32): i8*;

fn print(input: String) {
    printf("%s", input.Bytes);
}

fn println(input: String) {
    printf("%s\n", input.Bytes);
}

fn readln(): String {
    let out = malloc(256);
    gets(out); // TODO: Don't use gets.

    new String(out, 256)
}